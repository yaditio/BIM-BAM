{
  "name": "bim-bam",
  "version": "1.1.0",
  "description": "BIM Viewer with conversion, property filters, similarity selection, and cutting planes",
  "main": "electron-main.cjs",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "node server.cjs",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:dev": "concurrently \"npm run dev:frontend\" \"electron .\"",
    "desktop:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@xeokit/xeokit-convert": "^1.1.18",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.0",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.bimbam.viewer",
    "productName": "BIM BAM",
    "directories": {
      "output": "dist_desktop"
    },
    "files": [
      "dist/**/*",
      "lib/**/*",
      "public/**/*",
      "electron-main.cjs",
      "server.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/favicon.ico"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/@xeokit/xeokit-convert/**/*",
      "uploads"
    ]
  }
}
