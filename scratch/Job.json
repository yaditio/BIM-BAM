{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "Job",
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "engine": {
                "type": "object",
                "properties": {
                  "name": {
                    "const": "xeoIfc"
                  },
                  "version": {
                    "enum": [
                      "5.6.10",
                      "5.6.11"
                    ]
                  },
                  "options": {
                    "type": "object",
                    "properties": {
                      "maxFileSizeInMB": {
                        "type": "number"
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "name",
                  "version"
                ],
                "additionalProperties": false
              },
              "id": {
                "type": "string"
              },
              "input": {
                "type": "string"
              },
              "operation": {
                "const": "convert/ifc/glb"
              }
            },
            "required": [
              "engine",
              "id",
              "input",
              "operation"
            ]
          },
          {
            "type": "object",
            "properties": {
              "engine": {
                "type": "object",
                "properties": {
                  "name": {
                    "const": "xeoRvt"
                  },
                  "version": {
                    "const": "0.2.0"
                  }
                },
                "required": [
                  "name",
                  "version"
                ],
                "additionalProperties": false
              },
              "id": {
                "type": "string"
              },
              "input": {
                "type": "string"
              },
              "operation": {
                "const": "convert/rvt/glb"
              }
            },
            "required": [
              "engine",
              "id",
              "input",
              "operation"
            ]
          },
          {
            "type": "object",
            "properties": {
              "engine": {
                "type": "object",
                "properties": {
                  "name": {
                    "const": "xeoStep"
                  },
                  "version": {
                    "const": "0.1.0"
                  }
                },
                "required": [
                  "name",
                  "version"
                ],
                "additionalProperties": false
              },
              "id": {
                "type": "string"
              },
              "input": {
                "type": "string"
              },
              "operation": {
                "const": "convert/step/glb"
              }
            },
            "required": [
              "engine",
              "id",
              "input",
              "operation"
            ]
          },
          {
            "type": "object",
            "properties": {
              "engine": {
                "type": "object",
                "properties": {
                  "name": {
                    "const": "xeokit-convert"
                  },
                  "options": {
                    "type": "object",
                    "properties": {
                      "includeMetadata": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "includeMetadata"
                    ],
                    "additionalProperties": false
                  },
                  "version": {
                    "const": "1.3.2"
                  }
                },
                "required": [
                  "name",
                  "options",
                  "version"
                ],
                "additionalProperties": false
              },
              "id": {
                "type": "string"
              },
              "input": {
                "type": "string"
              },
              "operation": {
                "const": "convert/glb/xkt"
              }
            },
            "required": [
              "engine",
              "id",
              "input",
              "operation"
            ]
          },
          {
            "type": "object",
            "properties": {
              "fileType": {
                "anyOf": [
                  {
                    "const": "archive",
                    "description": "archive - Set of compressed into zip files"
                  },
                  {
                    "const": "glb",
                    "description": "glb - Binary glTF file"
                  },
                  {
                    "const": "ifc",
                    "description": "ifc - Industry Foundation Class"
                  },
                  {
                    "const": "rvt",
                    "description": "rvt - Autodesk Revit File"
                  },
                  {
                    "const": "step",
                    "description": "step - STEP File"
                  },
                  {
                    "const": "unknown",
                    "description": "unknown - Unknown or unsupported file type"
                  },
                  {
                    "const": "xeokit-manifest",
                    "description": "xeokit-manifest - xeokit manifest file"
                  },
                  {
                    "const": "xeokit-metadata",
                    "description": "xeokit-metadata - xeokit metadata file"
                  },
                  {
                    "const": "xkt",
                    "description": "xkt - xeokit native file"
                  }
                ]
              },
              "id": {
                "type": "string"
              },
              "operation": {
                "const": "import/url"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "fileType",
              "id",
              "operation",
              "url"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "input": {
                "type": "string"
              },
              "operation": {
                "const": "export/upload"
              },
              "urlTargets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "fileType": {
                      "anyOf": [
                        {
                          "const": "archive",
                          "description": "archive - Set of compressed into zip files"
                        },
                        {
                          "const": "glb",
                          "description": "glb - Binary glTF file"
                        },
                        {
                          "const": "ifc",
                          "description": "ifc - Industry Foundation Class"
                        },
                        {
                          "const": "rvt",
                          "description": "rvt - Autodesk Revit File"
                        },
                        {
                          "const": "step",
                          "description": "step - STEP File"
                        },
                        {
                          "const": "unknown",
                          "description": "unknown - Unknown or unsupported file type"
                        },
                        {
                          "const": "xeokit-manifest",
                          "description": "xeokit-manifest - xeokit manifest file"
                        },
                        {
                          "const": "xeokit-metadata",
                          "description": "xeokit-metadata - xeokit metadata file"
                        },
                        {
                          "const": "xkt",
                          "description": "xkt - xeokit native file"
                        }
                      ]
                    },
                    "url": {
                      "type": "string",
                      "format": "uri"
                    }
                  },
                  "required": [
                    "fileType",
                    "url"
                  ]
                }
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "input",
              "operation",
              "urlTargets"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "input": {
                "type": "string"
              },
              "operation": {
                "const": "export/url"
              },
              "archiveMultipleFiles": {
                "type": "boolean"
              }
            },
            "required": [
              "id",
              "input",
              "operation"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "tag": {
      "type": "string"
    },
    "webhook": {
      "type": "object",
      "properties": {
        "eventTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "job.failed",
              "job.started",
              "job.succeeded"
            ]
          }
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "eventTypes",
        "url"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "tasks"
  ],
  "additionalProperties": false
}